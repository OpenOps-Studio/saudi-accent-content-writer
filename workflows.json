{
  "version": "2.1",
  "workflows": [
    {
      "id": "generate_captions",
      "name": "Generate Multi-Platform Captions (Saudi)",
      "inputs": ["brand_tone", "offer", "audience", "platforms[]"],
      "steps": [
        "BriefSynthesis",
        "NormalizeBrief",
        "DialectSearch",
        "DialectGuard",
        "TrendRadar",
        "CaptionSynthesis",
        "DialectEnforcer",
        "PlatformFit",
        "VoiceConsistencyLint",
        "ClaimProofing",
        "ComplianceCheck",
        "CTAInsertion",
        "FinalizePackage"
      ],
      "outputs": ["captions_by_platform", "hashtags", "on_design_text_suggestions"],
      "quality_gates": ["Dialect", "Compliance", "PlatformFit"]
    },
    {
      "id": "write_linkedin_post",
      "name": "Write LinkedIn Post/Article (Saudi Pro Tone)",
      "inputs": ["topic", "insights", "evidence", "cta"],
      "steps": [
        "BriefSynthesis",
        "DialectSearch",
        "OutlineBuild",
        "SaudiProToneAdjust",
        "DialectEnforcer",
        "EvidenceAttach",
        "VoiceConsistencyLint",
        "ClaimProofing",
        "ComplianceCheck",
        "FormatForLinkedIn"
      ],
      "outputs": ["post", "article_outline"],
      "quality_gates": ["Accuracy", "Compliance", "Readability"]
    },
    {
      "id": "build_calendar",
      "name": "Build Social Media Calendar",
      "inputs": ["brand", "month", "strategic_themes[]", "priority_platforms[]"],
      "steps": [
        "BriefSynthesis",
        "DialectSearch",
        "TrendRadar",
        "ThemeSpread",
        "IdeaGenerator",
        "CaptionSynthesis",
        "DialectEnforcer",
        "DesignIdeaMap",
        "KPIAssign",
        "VoiceConsistencyLint",
        "CalendarAssemble",
        "ReviewAndGate"
      ],
      "outputs": ["yaml_calendar", "csv_headers", "weekly_breakdown"],
      "quality_gates": ["Coverage", "Dialect", "Compliance", "PlatformFit"]
    },
    {
      "id": "x_sensitive_statement",
      "name": "X/Twitter Sensitive Statement (KSA)",
      "inputs": ["topic", "position", "stakeholders", "risk_level"],
      "steps": [
        "BriefSynthesis",
        "DialectSearch",
        "DialectGuard",
        "RiskScreen",
        "XRiskMonitor",
        "DialectEnforcer",
        "ClaimProofing",
        "ComplianceCheck",
        "FinalizePackage"
      ],
      "outputs": ["statement", "safer_alternatives", "escalation_needed"],
      "quality_gates": ["Risk", "Compliance", "Dialect"]
    },
    {
      "id": "seo_snippet_pack",
      "name": "Arabic SEO Snippet Pack (Saudi Tone)",
      "inputs": ["topic", "keywords[]", "audience", "tone"],
      "steps": [
        "BriefSynthesis",
        "DialectSearch",
        "SEOSnippetBuild",
        "DialectEnforcer",
        "VoiceConsistencyLint",
        "ComplianceCheck"
      ],
      "outputs": ["title", "meta_description", "h1", "faq"],
      "quality_gates": ["Compliance", "Readability"]
    }
  ],
