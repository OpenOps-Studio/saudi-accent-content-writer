  "outputs": {
    "normalized_text": "string",
    "notes": "optional<string>"
  },
  "examples": [
    {
      "text": "نقدم عرض خاص للغاية",
      "tone": "warm",
      "result": "عندنا عرض خرافي اليوم"
    }
  ],
